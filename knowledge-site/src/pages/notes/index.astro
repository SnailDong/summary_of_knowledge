---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageBack from '../../components/PageBack.astro';

const studyCount = Object.keys(import.meta.glob('../../content/notes/**/study*.md')).length;
const allNotes = Object.keys(import.meta.glob('../../content/notes/**/*.md'));
const interviewCount = allNotes.filter((path) => path.includes('/interview/')).length;
const technicalCount = allNotes.filter((path) => {
  const fileName = path.split('/').at(-1);
  return !path.includes('/interview/') && !fileName.startsWith('study') && fileName.toLowerCase() !== 'readme.md';
}).length;
---

<BaseLayout title="技术笔记 - 蜗牛之家">
  <PageBack />
  <section class="section-header">
    <p class="eyebrow">Technical Notes</p>
    <h1>技术笔记</h1>
    <p>这里分成学习笔记、技术笔记和面试问答，方便按阅读目的进入。</p>
  </section>

  <div class="article-grid">
    <a class="article-card" href="/notes/study/">
      <span>{studyCount} 篇</span>
      <strong>学习笔记</strong>
      <p>按学习过程记录的 Android UI、源码阅读和实践笔记。</p>
    </a>
    <a class="article-card" href="/notes/technical/">
      <span>{technicalCount} 篇</span>
      <strong>技术笔记</strong>
      <p>Java、Android Framework、性能优化、开源库、网络数据库等主题笔记。</p>
    </a>
    <a class="article-card" href="/notes/interview/">
      <span>{interviewCount} 篇</span>
      <strong>面试问答</strong>
      <p>围绕个人定位、项目经验、技术名词和压力追问整理的面试回答手册。</p>
    </a>
  </div>
</BaseLayout>
