---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleList from '../../../components/ArticleList.astro';
import PageBack from '../../../components/PageBack.astro';
import { buildItems, isStudyNotePath, omitReadmePath } from '../../../lib/content.js';

const modules = import.meta.glob('../../../content/notes/**/*.md');
const studyModules = Object.fromEntries(
  Object.entries(modules).filter(([path]) => omitReadmePath(path) && isStudyNotePath(path))
);
const items = buildItems(studyModules, '../../../content/notes/', '/notes', '学习笔记');
---

<BaseLayout title="学习笔记 - 技术笔记">
  <PageBack href="/notes/" label="返回技术笔记" />
  <ArticleList
    title="学习笔记"
    description="按学习过程记录的 Android UI、源码阅读和实践笔记。"
    items={items}
  />
</BaseLayout>
