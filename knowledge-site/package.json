{
  "name": "knowledge-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync": "node scripts/sync-content.mjs",
    "dev": "npm run sync && ASTRO_TELEMETRY_DISABLED=1 astro dev --host 0.0.0.0",
    "build": "npm run sync && ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview --host 0.0.0.0",
    "check:content": "node scripts/check-content.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.0.0",
    "astro": "^5.0.0"
  },
  "devDependencies": {}
}
